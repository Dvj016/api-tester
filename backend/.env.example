# Backend Configuration

# CORS Origins (comma-separated)

# MongoDB Atlas (for persistent visitor counter)
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
CORS_ORIGINS=http://localhost:3000,https://api-tester-taupe.vercel.app

# Email Configuration (for feedback form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FEEDBACK_EMAIL=your_email@gmail.com